---
const platos = [
  {
    tiempo: "Desayuno",
    nombre: "Chilaquiles Tradicionales",
    desc: "Bañados en salsa verde fresca, coronados con crema y queso.",
    img: "/img/Comidas/Desayuno.webp",
  },
  {
    tiempo: "Almuerzo",
    nombre: "Tacos de Autor",
    desc: "Tortilla artesanal con el toque vibrante de nuestra receta especial.",
    img: "/img/Comidas/Almuerzo.webp",
  },
  {
    tiempo: "Cena",
    nombre: "Enchiladas Suizas",
    desc: "Gratinadas con queso premium y nuestra cremosa salsa verde.",
    img: "/img/Comidas/Cena.webp",
  },
];
---

<section id="gastronomia" class="bg-crema-logo py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 reveal border-l-4 border-verde-brand pl-8">
      <span
        class="text-verde-brand font-bold tracking-[0.4em] text-sm mb-2 block"
        >Gastronomía</span
      >
      <h2
        class="text-4xl md:text-6xl font-black italic font-serif text-verde-profundo leading-none"
      >
        Momentos para <br />
        <span class="text-verde-brand">degustar</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 mb-20">
      {
        platos.map((p) => (
          <div class="reveal group relative flex flex-col h-full">
            <div class="relative h-[400px] md:h-[500px] rounded-[2.5rem] overflow-hidden shadow-2xl bg-verde-profundo">
              <img
                src={p.img}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-in-out"
                alt={p.nombre}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60" />

              <div class="absolute top-6 left-6 bg-verde-brand text-white px-4 py-2 rounded-full text-sm font-bold tracking-widest shadow-lg">
                {p.tiempo}
              </div>
            </div>

            <div class="mt-8 px-4">
              <h3 class="text-verde-profundo text-2xl md:text-3xl font-black italic font-serif mb-3 leading-tight">
                {p.nombre}
              </h3>
              <p class="text-verde-profundo/70 text-sm font-medium leading-relaxed italic max-w-xs">
                {p.desc}
              </p>
              <div class="mt-4 w-12 h-[1px] bg-verde-brand group-hover:w-full transition-all duration-700 opacity-30" />
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="reveal bg-verde-profundo rounded-[3rem] p-10 md:p-16 text-center relative overflow-hidden shadow-2xl"
    >
      <div
        class="absolute -left-10 -top-10 w-40 h-40 bg-verde-brand/10 rounded-full blur-3xl"
      >
      </div>

      <div class="relative z-10">
        <h4
          class="text-verde-brand font-black uppercase tracking-[0.5em] text-[10px] mb-6"
        >
          Versatilidad Infinita
        </h4>
        <p
          class="text-crema-logo text-2xl md:text-4xl font-serif italic leading-snug max-w-3xl mx-auto mb-8"
        >
          "Desde snacks rápidos hasta banquetes de gala, nuestra salsa verde es
          el <span class="text-verde-brand underline underline-offset-8"
            >acompañante universal</span
          > para cualquier creación culinaria."
        </p>
        <p
          class="text-crema-logo/40 text-[10px] font-bold uppercase tracking-widest"
        >
          Enchiladas • Tostadas • Huevos • Carnes • Mariscos
        </p>
      </div>
    </div>
  </div>
</section>
