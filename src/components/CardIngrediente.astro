---
interface Props {
  titulo: string;
  imagen: string;
  descripcion: string;
}

const { titulo, descripcion, imagen } = Astro.props;
---

<div
  class="reveal group bg-white/40 backdrop-blur-sm rounded-[2rem] overflow-hidden border border-verde-brand/10 hover:border-verde-brand hover:shadow-2xl transition-all duration-500"
>
  <div class="relative aspect-video overflow-hidden bg-verde-profundo/5">
    <img
      src={imagen}
      alt={titulo}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 ease-out"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-verde-profundo/20 to-transparent"
    >
    </div>
  </div>

  <div class="p-8">
    <div class="flex items-center gap-2.5 mb-3">
      <div
        class="w-2 h-2 bg-verde-brand rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 ease-out"
      >
      </div>

      <h3
        class="text-2xl font-black text-verde-profundo tracking-tight leading-tight italic font-serif"
      >
        {titulo}
      </h3>
    </div>

    <p class="text-[14px] text-verde-profundo/70 leading-relaxed font-medium">
      {descripcion}
    </p>

    <div
      class="mt-6 w-8 h-[1px] bg-verde-brand/20 group-hover:w-12 group-hover:bg-verde-brand transition-all duration-500"
    >
    </div>
  </div>
</div>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>
