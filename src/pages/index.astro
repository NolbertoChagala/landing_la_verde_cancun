---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MenuMomentos from "../components/MenuMomentos.astro";
import CardIngrediente from "../components/CardIngrediente.astro";
import { Quote, Leaf, Check, Star, MoveRight, ChevronDown } from "lucide-astro";
---

<Layout title="La Verde de Cancún">
  <Navbar />

  <header
    class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden bg-crema-logo"
  >
    <div class="absolute inset-0 z-0">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-verde-brand/15 via-transparent to-transparent"
      >
      </div>

      <div
        class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/paper-fibers.png')]"
      >
      </div>
    </div>

    <div
      class="relative z-10 flex flex-col items-center max-w-5xl mx-auto text-center"
    >
      <div class="reveal mb-12 relative group">
        <div
          class="absolute inset-0 bg-verde-brand/20 blur-3xl rounded-full scale-150 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"
        >
        </div>

        <img
          src="/img/La_verde_cancun.webp"
          width="280"
          height="280"
          class="relative w-48 md:w-72 h-auto drop-shadow-[0_20px_50px_rgba(124,179,66,0.3)] transition-transform duration-700 hover:scale-105"
          alt="Logo La Verde de Cancún"
        />
      </div>

      <div class="reveal delay-200">
        <h1
          class="text-6xl md:text-[9rem] font-black tracking-tighter leading-[0.85] text-verde-profundo mb-6"
        >
          Sabor que <br />
          <span class="text-verde-brand italic font-serif relative">
            Despierta
            <svg
              class="absolute -bottom-2 left-0 w-full h-3 text-verde-brand/30"
              viewBox="0 0 100 10"
              preserveAspectRatio="none"
            >
              <path
                d="M0 5 Q 25 0, 50 5 T 100 5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"></path>
            </svg>
          </span>
        </h1>

        <div class="flex flex-col items-center gap-4">
          <p
            class="text-verde-brand font-black uppercase tracking-[0.6em] text-[10px] md:text-sm bg-verde-brand/5 px-6 py-2 rounded-full border border-verde-brand/10"
          >
            Tradición Artesanal
          </p> 
        </div>
      </div>
    </div>

    <div
      class="absolute top-10 left-10 w-24 h-24 border-t-2 border-l-2 border-verde-brand/10 hidden md:block"
    >
    </div>
    <div
      class="absolute bottom-10 right-10 w-24 h-24 border-b-2 border-r-2 border-verde-brand/10 hidden md:block"
    >
    </div>
  </header>

  <section id="nosotros" class="py-24 px-6 bg-crema-logo">
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center"
    >
      <div class="reveal">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-[1px] w-8 bg-verde-brand"></div>
          <span
            class="text-verde-brand font-bold text-xs uppercase tracking-[0.3em]"
            >Nuestra Identidad</span
          >
        </div>

        <h2
          class="text-4xl md:text-6xl font-black mb-8 italic font-serif text-verde-profundo"
        >
          ¿Qué somos?
        </h2>

        <p
          class="text-xl md:text-2xl leading-relaxed mb-6 text-verde-profundo/80"
        >
          Nacida en el corazón de Quintana Roo, nuestra salsa es el equilibrio
          perfecto entre la frescura del <span
            class="text-verde-brand font-bold italic">tomatillo</span
          > y el carácter del <span class="text-verde-brand font-bold italic"
            >chile serrano</span
          >.
        </p>

        <p class="text-base opacity-60 mb-8 leading-relaxed">
          Diseñada para elevar cada platillo, desde los chilaquiles del desayuno
          hasta la cena más sofisticada. No es solo una salsa, es el alma de tu
          mesa.
        </p>
      </div>

      <div
        class="reveal delay-300 bg-verde-profundo p-12 rounded-[3rem] text-crema-logo shadow-2xl relative overflow-hidden group border border-white/5"
      >
        <Leaf
          class="absolute -right-8 -bottom-8 text-verde-brand/10 rotate-12 group-hover:rotate-45 transition-transform duration-1000"
          size={220}
        />

        <div class="relative z-10">
          <h4
            class="text-verde-brand font-black uppercase tracking-[0.4em] text-[10px] mb-8"
          >
            La Esencia
          </h4>

          <ul class="space-y-6">
            {
              [
                { txt: "Sabor Mexicano Real", icon: Check },
                { txt: "Ingredientes Locales", icon: Check },
                { txt: "Calidad de Exportación", icon: Check },
              ].map((item) => (
                <li class="flex items-center gap-4 text-lg font-medium group/item">
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-verde-brand/20 flex items-center justify-center group-hover/item:bg-verde-brand transition-colors duration-300">
                    <item.icon
                      size={14}
                      class="text-verde-brand group-hover/item:text-verde-profundo transition-colors"
                    />
                  </div>
                  <span class="group-hover/item:translate-x-2 transition-transform duration-300">
                    {item.txt}
                  </span>
                </li>
              ))
            }
          </ul>

          <div class="mt-12 pt-8 border-t border-white/10">
            <p
              class="text-[10px] uppercase tracking-widest font-bold opacity-40 italic"
            >
              Hecho con ingredientes 100% frescos de Cancún
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <MenuMomentos />

  <section
    id="ingredientes"
    class="py-24 px-6 bg-crema-logo relative overflow-hidden"
  >
    <div
      class="absolute top-0 right-0 w-64 h-64 bg-verde-brand/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"
    >
    </div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="mb-16 reveal">
        <span
          class="text-verde-brand font-black uppercase tracking-[0.4em] text-[10px] mb-2 block"
          >Ingredientes</span
        >
        <h2
          class="text-4xl md:text-6xl font-black italic font-serif text-verde-profundo tracking-tighter"
        >
          Ingredientes <span class="text-verde-brand">Seleccionados</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <CardIngrediente
          titulo="Chile Serrano"
          imagen="/img/Ingredientes/Chile_serrano.webp"
          descripcion="El picor vibrante que define el carácter de nuestra salsa."
        />
        <CardIngrediente
          titulo="Cebolla"
          imagen="/img/Ingredientes/Cebolla.webp"
          descripcion="Aporta la textura y el dulzor sutil que equilibra cada bocado."
        />
        <CardIngrediente
          titulo="Cilantro"
          imagen="/img/Ingredientes/Cilantro.webp"
          descripcion="Frescura herbal recolectada localmente para un aroma inigualable."
        />
        <CardIngrediente
          titulo="Ajo"
          imagen="/img/Ingredientes/Ajo.webp"
          descripcion="El secreto aromático que potencia la intensidad de nuestros sabores."
        />
        <CardIngrediente
          titulo="Aguacate"
          imagen="/img/Ingredientes/Aguacate.webp"
          descripcion="Cremosidad premium que da cuerpo y suavidad a la mezcla."
        />
        <CardIngrediente
          titulo="Tomate Verde"
          imagen="/img/Ingredientes/Tomate_verde.webp"
          descripcion="Base ácida y vibrante, la esencia pura de La Verde de Cancún."
        />
        <CardIngrediente
          titulo="Sal"
          imagen="/img/Ingredientes/Sal.webp"
          descripcion="Mineral seleccionado para resaltar cada nota de nuestra receta."
        />
        <CardIngrediente
          titulo="Agua"
          imagen="/img/Ingredientes/Agua.webp"
          descripcion="Pureza cristalina para lograr la consistencia perfecta."
        />
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-crema-logo overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="reveal relative mb-12">
        <div
          class="rounded-[3rem] overflow-hidden bg-verde-profundo/5 aspect-[16/9] md:aspect-[21/9] shadow-2xl border border-verde-brand/10"
        >
          <img
            src="/img/Comida.webp"
            alt="Presentación La Verde de Cancún"
            class="w-full h-full object-cover"
          />
        </div>

        <div
          class="absolute -bottom-6 -right-2 md:right-12 bg-verde-brand text-white p-6 md:p-10 rounded-full shadow-2xl flex flex-col items-center justify-center rotate-12 hover:rotate-0 transition-transform duration-500 border-4 border-crema-logo z-20"
        >
          <span
            class="text-[10px] font-black uppercase tracking-widest opacity-80 mb-1"
            >Solo por</span
          >
          <div class="flex items-start">
            <span class="text-xl font-bold mt-1">$</span>
            <span
              class="text-5xl md:text-6xl font-black tracking-tighter leading-none"
              >18</span
            >
          </div>
          <div class="w-8 h-px bg-white/30 my-2"></div>
          <span class="text-[9px] font-bold uppercase tracking-tighter"
            >100ml de sabor</span
          >
        </div>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-16 items-start mt-16"
      >
        <div class="lg:col-span-5 reveal">
          <div class="flex items-center gap-3 mb-6">
            <div
              class="w-10 h-10 rounded-full bg-verde-brand/10 flex items-center justify-center"
            >
              <Star class="text-verde-brand" size={18} fill="currentColor" />
            </div>
            <h4
              class="text-[10px] font-black uppercase tracking-[0.4em] text-verde-brand"
            >
              Edición Limitada
            </h4>
          </div>

          <h2
            class="text-4xl md:text-6xl font-black italic font-serif leading-[1.1] text-verde-profundo mb-8 tracking-tighter"
          >
            Pura frescura <br />
            <span class="text-verde-brand">en tu mesa.</span>
          </h2>

          <div class="space-y-6">
            <p
              class="text-verde-profundo/70 leading-relaxed font-medium text-lg italic"
            >
              Nuestra botella de 60ml no es solo salsa, es un concentrado de
              tradición cancunense.
            </p>
            <div
              class="flex items-center gap-4 text-verde-profundo/40 text-[10px] font-black uppercase tracking-widest"
            >
              <span>Envase Reciclable</span>
              <div class="w-1 h-1 bg-verde-brand rounded-full"></div>
              <span>100% Natural</span>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 reveal delay-200">
          <div
            class="bg-verde-profundo p-10 md:p-14 rounded-[3rem] relative shadow-2xl border border-white/5 overflow-hidden group"
          >
            <div
              class="absolute -right-20 -bottom-20 w-64 h-64 bg-verde-brand/5 rounded-full blur-3xl"
            >
            </div>

            <div class="flex items-center gap-4 mb-8">
              <div
                class="w-12 h-12 rounded-2xl bg-verde-brand/20 flex items-center justify-center"
              >
                <Quote class="text-verde-brand" size={24} fill="currentColor" />
              </div>
              <span
                class="text-verde-brand font-black uppercase tracking-[0.4em] text-xs"
                >Recomendación</span
              >
            </div>

            <p
              class="text-2xl md:text-4xl italic font-serif leading-tight text-crema-logo mb-10 relative z-10"
            >
              "Un toque de <span class="text-verde-brand">salsa verde</span> transforma
              un platillo ordinario en algo extraordinario."
            </p>

            <div
              class="flex items-center justify-between pt-8 border-t border-white/10"
            >
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 bg-verde-brand rounded-full animate-pulse">
                </div>
                <span
                  class="text-white/40 text-[9px] font-bold uppercase tracking-widest"
                  >Sello de Calidad</span
                >
              </div>
              <div
                class="flex items-center gap-3 text-verde-brand font-black text-[10px] uppercase tracking-widest group-hover:gap-5 transition-all"
              >
                <span>Tip del Chef</span>
                <MoveRight size={16} />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("active");
      });
    },
    { threshold: 0.1 },
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
